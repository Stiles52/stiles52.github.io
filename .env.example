# ============================================================
#  ORIGIN — Modèle de configuration
#  Copier ce fichier en ".env" et remplir les valeurs
# ============================================================

# --- Application ---
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/origin-web
APP_SECRET_KEY=
APP_NAME="ORIGIN RP"

# --- Base de données ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=origin_db
DB_USERNAME=root
DB_PASSWORD=

# --- Session ---
SESSION_LIFETIME=120
SESSION_SECURE=false

# --- Mail / SMTP ---
# log = enregistre dans storage/mail-log/ (dev) | smtp = envoi réel (prod)
MAIL_DRIVER=log
MAIL_FROM_ADDRESS=no-reply@origin-rp.fr
MAIL_FROM_NAME="ORIGIN RP"
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ENCRYPTION=tls

# --- Discord Webhook (tickets support) ---
# Créer depuis : Paramètres du serveur > Intégrations > Webhooks
DISCORD_WEBHOOK=

# --- Discord OAuth (connexion via Discord) ---
# Créer depuis : https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=${APP_URL}/auth/discord/callback

# --- Microsoft OAuth (connexion via Microsoft) ---
# Créer depuis : https://portal.azure.com > App registrations
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=${APP_URL}/auth/microsoft/callback
